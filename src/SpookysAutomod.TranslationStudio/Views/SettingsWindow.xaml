<Window x:Class="SpookysAutomod.TranslationStudio.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Translation Studio Settings"
        Height="760" Width="820"
        MinHeight="680" MinWidth="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Settings"
                       FontFamily="{DynamicResource PrimaryFont}"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Edit AI translation and theme preferences. Changes are saved to settings.json."
                       Margin="0,6,0,0"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock Text="{Binding ConfigFilePath, StringFormat='Config file: {0}'}"
                       Margin="0,6,0,0"
                       Foreground="{DynamicResource TextDimBrush}"
                       FontFamily="{DynamicResource MonoFont}"
                       FontSize="11"
                       TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,20,0,20" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{DynamicResource CardPanel}">
                    <StackPanel>
                        <TextBlock Text="Theme"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="Choose whether the app follows the system theme or uses a fixed light/dark theme."
                                   Margin="0,4,0,12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                        <ComboBox ItemsSource="{Binding ThemeModes}"
                                  SelectedItem="{Binding SelectedThemeMode, Mode=TwoWay}"
                                  DisplayMemberPath="Label"
                                  Style="{DynamicResource DarkComboBox}"
                                  Width="220" />
                    </StackPanel>
                </Border>

                <Border Style="{DynamicResource CardPanel}" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="AI Translation"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="Configure the endpoint, model, prompts, and cache/report paths used by the standalone Translation Studio."
                                   Margin="0,4,0,12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />

                        <TextBlock Text="Endpoint" Foreground="{DynamicResource TextDimBrush}" />
                        <TextBox Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource DarkTextBox}" Margin="0,4,0,12" />

                        <TextBlock Text="API Key" Foreground="{DynamicResource TextDimBrush}" />
                        <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource DarkTextBox}" Margin="0,4,0,12" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Model" Foreground="{DynamicResource TextDimBrush}" />
                                <TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource DarkTextBox}" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Dictionary Directory" Foreground="{DynamicResource TextDimBrush}" />
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding DictionaryDirectory, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource DarkTextBox}" />
                                    <Button Grid.Column="2"
                                            Content="Browse..."
                                            Style="{DynamicResource SecondaryButton}"
                                            Padding="14,8"
                                            Command="{Binding BrowseDictionaryDirectoryCommand}" />
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Batch Size" Foreground="{DynamicResource TextDimBrush}" />
                                <TextBox Text="{Binding BatchSize, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource DarkTextBox}" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Hint Count" Foreground="{DynamicResource TextDimBrush}" />
                                <TextBox Text="{Binding DictionaryHintLimit, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource DarkTextBox}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Cache File" Foreground="{DynamicResource TextDimBrush}" />
                                <TextBox Text="{Binding CacheFile, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource DarkTextBox}" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Report File" Foreground="{DynamicResource TextDimBrush}" />
                                <TextBox Text="{Binding ReportFile, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource DarkTextBox}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Max English Hint Length" Foreground="{DynamicResource TextDimBrush}" />
                                <TextBox Text="{Binding MaxHintEnglishLength, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource DarkTextBox}" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Max Chinese Hint Length" Foreground="{DynamicResource TextDimBrush}" />
                                <TextBox Text="{Binding MaxHintChineseLength, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource DarkTextBox}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Min Confidence" Foreground="{DynamicResource TextDimBrush}" />
                                <TextBox Text="{Binding MinConfidence, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource DarkTextBox}" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Max Output Tokens" Foreground="{DynamicResource TextDimBrush}" />
                                <TextBox Text="{Binding MaxOutputTokens, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource DarkTextBox}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="System Prompt" Foreground="{DynamicResource TextDimBrush}" />
                        <TextBox Text="{Binding SystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource DarkTextBox}"
                                 Margin="0,4,0,12"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="140"
                                 VerticalScrollBarVisibility="Auto" />

                        <TextBlock Text="User Prompt Preamble" Foreground="{DynamicResource TextDimBrush}" />
                        <TextBox Text="{Binding UserPromptPreamble, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource DarkTextBox}"
                                 Margin="0,4,0,0"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="110"
                                 VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{DynamicResource SecondaryButton}"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Margin="0,0,8,0" />
            <Button Content="Save Settings"
                    Style="{DynamicResource PrimaryButton}"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
        </StackPanel>
    </Grid>
</Window>
