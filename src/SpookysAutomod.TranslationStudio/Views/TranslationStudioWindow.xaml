<Window x:Class="SpookysAutomod.TranslationStudio.Views.TranslationStudioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spooky's Translation Studio"
        Height="820" Width="1360"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Spooky's Translation Studio"
                               FontFamily="{DynamicResource PrimaryFont}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="Standalone translation workbench for XML exports, local review, and AI-assisted batch translation."
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                        <TextBlock Text="Theme"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <ComboBox Width="150"
                                  ItemsSource="{Binding ThemeModes}"
                                  SelectedItem="{Binding SelectedThemeMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{DynamicResource DarkComboBox}"
                                  DisplayMemberPath="Label" />
                        <TextBlock Text="{Binding ResolvedThemeLabel, StringFormat='Now: {0}'}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="{Binding ConfigFilePath, StringFormat='Config: {0}'}"
                               FontSize="11"
                               Foreground="{DynamicResource TextDimBrush}"
                               FontFamily="{DynamicResource MonoFont}" />
                    <TextBlock Text="{Binding CurrentFilePath, StringFormat='File: {0}'}"
                               FontSize="11"
                               Foreground="{DynamicResource TextDimBrush}"
                               FontFamily="{DynamicResource MonoFont}"
                               TextTrimming="CharacterEllipsis"
                               Width="460" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,1"
                Padding="24,14">
            <StackPanel>
                <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="Open File" Style="{DynamicResource PrimaryButton}"
                            Command="{Binding OpenFileCommand}" Margin="0,0,8,8" />
                    <Button Content="Save" Style="{DynamicResource SecondaryButton}"
                            Command="{Binding SaveCommand}" Margin="0,0,8,8" />
                    <Button Content="Save As" Style="{DynamicResource SecondaryButton}"
                            Command="{Binding SaveAsCommand}" Margin="0,0,8,8" />
                    <Button Content="Translate Selected" Style="{DynamicResource SecondaryButton}"
                            Command="{Binding TranslateSelectedCommand}" Margin="0,0,8,8" />
                    <Button Content="Translate Pending" Style="{DynamicResource PrimaryButton}"
                            Command="{Binding TranslateAllCommand}" Margin="0,0,8,8" />
                    <Button Content="Stop" Style="{DynamicResource SecondaryButton}"
                            Command="{Binding StopTranslationCommand}" Margin="0,0,8,8" />
                    <Button Content="Settings" Style="{DynamicResource SecondaryButton}"
                            Command="{Binding OpenSettingsCommand}" Margin="0,0,8,8" />
                </WrapPanel>

                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="Pending Only"
                              IsChecked="{Binding ShowPendingOnly}"
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              VerticalAlignment="Center"
                              Margin="0,0,14,0" />
                    <ComboBox Width="120"
                              ItemsSource="{Binding StatusFilters}"
                              SelectedItem="{Binding SelectedStatusFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{DynamicResource DarkComboBox}"
                              Margin="0,0,12,0" />
                    <TextBox Width="260"
                             Style="{DynamicResource DarkTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="24,18,24,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.6*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.9*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{DynamicResource CardPanel}" Padding="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource SurfaceLightBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Entry List"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding TotalCount, StringFormat='Total: {0}'}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextDimBrush}" />
                        </Grid>
                    </Border>

                    <ListBox ItemsSource="{Binding EntriesView}"
                             SelectedItem="{Binding SelectedEntry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Foreground="{DynamicResource TextPrimaryBrush}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="Transparent"
                                                    Padding="10,10,10,12">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceLightBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceLightBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12">
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock DockPanel.Dock="Left"
                                                       Text="{Binding StatusLabel}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextDimBrush}" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding ConfidenceLabel}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextDimBrush}" />
                                        </DockPanel>

                                        <Border Background="{DynamicResource BackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10"
                                                Margin="0,8,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Original"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextDimBrush}" />
                                                <TextBlock Text="{Binding Source}"
                                                           Margin="0,6,0,0"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextWrapping="Wrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxHeight="60" />
                                            </StackPanel>
                                        </Border>

                                        <Border Background="{DynamicResource AccentDarkBrush}"
                                                BorderBrush="{DynamicResource AccentBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10"
                                                Margin="0,8,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Translation"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentForegroundBrush}"
                                                           Opacity="0.8" />
                                                <TextBlock Text="{Binding Dest}"
                                                           Margin="0,6,0,0"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentForegroundBrush}"
                                                           TextWrapping="Wrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxHeight="72" />
                                            </StackPanel>
                                        </Border>

                                        <WrapPanel Margin="0,8,0,0">
                                            <TextBlock Text="{Binding Edid}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextDimBrush}"
                                                       Margin="0,0,12,0" />
                                            <TextBlock Text="{Binding Record}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextDimBrush}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{DynamicResource CardPanel}" Margin="0,0,0,12">
                    <UniformGrid Columns="4" Rows="2">
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="All" FontSize="11" Foreground="{DynamicResource TextDimBrush}" />
                            <TextBlock Text="{Binding TotalCount}" FontSize="20" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Pending" FontSize="11" Foreground="{DynamicResource TextDimBrush}" />
                            <TextBlock Text="{Binding PendingCount}" FontSize="20" Foreground="{DynamicResource WarningBrush}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="AI" FontSize="11" Foreground="{DynamicResource TextDimBrush}" />
                            <TextBlock Text="{Binding AiCount}" FontSize="20" Foreground="{DynamicResource SuccessBrush}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Cached" FontSize="11" Foreground="{DynamicResource TextDimBrush}" />
                            <TextBlock Text="{Binding CachedCount}" FontSize="20" Foreground="{DynamicResource AccentBrush}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Review" FontSize="11" Foreground="{DynamicResource TextDimBrush}" />
                            <TextBlock Text="{Binding ReviewCount}" FontSize="20" Foreground="{DynamicResource WarningBrush}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Failed" FontSize="11" Foreground="{DynamicResource TextDimBrush}" />
                            <TextBlock Text="{Binding FailedCount}" FontSize="20" Foreground="{DynamicResource ErrorBrush}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Edited" FontSize="11" Foreground="{DynamicResource TextDimBrush}" />
                            <TextBlock Text="{Binding EditedCount}" FontSize="20" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                        <Border Background="Transparent" />
                    </UniformGrid>
                </Border>

                <Border Grid.Row="1" Style="{DynamicResource CardPanel}" DataContext="{Binding SelectedEntry}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Translation Focus"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />

                            <Border Background="{DynamicResource BackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,14,0,0">
                                <StackPanel>
                                    <TextBlock Text="Original"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextDimBrush}"
                                               Margin="0,0,0,8" />
                                    <TextBox Text="{Binding Source, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             FontSize="18"
                                             FontWeight="SemiBold"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             MinHeight="150"
                                             VerticalScrollBarVisibility="Auto" />
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource AccentDarkBrush}"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,14,0,0">
                                <StackPanel>
                                    <TextBlock Text="Translation"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentForegroundBrush}"
                                               Opacity="0.8"
                                               Margin="0,0,0,8" />
                                    <TextBox Text="{Binding Dest, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="False"
                                             IsEnabled="True"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource AccentForegroundBrush}"
                                             CaretBrush="{DynamicResource AccentForegroundBrush}"
                                             FontSize="20"
                                             FontWeight="SemiBold"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             MinHeight="190"
                                             VerticalScrollBarVisibility="Auto" />
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource SurfaceLightBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,14,0,0">
                                <StackPanel>
                                    <TextBlock Text="Context"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextDimBrush}" />
                                    <WrapPanel Margin="0,8,0,0">
                                        <TextBlock Text="EDID: "
                                                   Foreground="{DynamicResource TextDimBrush}"
                                                   FontSize="11" />
                                        <TextBlock Text="{Binding Edid}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="11"
                                                   Margin="0,0,16,0" />
                                        <TextBlock Text="REC: "
                                                   Foreground="{DynamicResource TextDimBrush}"
                                                   FontSize="11" />
                                        <TextBlock Text="{Binding Record}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="11"
                                                   Margin="0,0,16,0" />
                                        <TextBlock Text="Status: "
                                                   Foreground="{DynamicResource TextDimBrush}"
                                                   FontSize="11" />
                                        <TextBlock Text="{Binding StatusLabel}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="11"
                                                   Margin="0,0,16,0" />
                                        <TextBlock Text="Confidence: "
                                                   Foreground="{DynamicResource TextDimBrush}"
                                                   FontSize="11" />
                                        <TextBlock Text="{Binding ConfidenceLabel}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="11" />
                                    </WrapPanel>

                                    <TextBlock Text="{Binding Notes}"
                                               Margin="0,8,0,0"
                                               Foreground="{DynamicResource TextDimBrush}"
                                               FontSize="11"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource SurfaceLightBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,14,0,0">
                                <StackPanel>
                                    <TextBlock Text="Dictionary Hints For This Entry"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextDimBrush}" />
                                    <ItemsControl ItemsSource="{Binding DataContext.SelectedEntryHints, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,0,0,6"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap">
                                                    <Run Text="{Binding English}" />
                                                    <Run Text=" => " />
                                                    <Run Text="{Binding Chinese}" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No dictionary hints matched this entry."
                                               Foreground="{DynamicResource TextDimBrush}"
                                               FontSize="11"
                                               Margin="0,2,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.SelectedEntryHints.Count, RelativeSource={RelativeSource AncestorType=Window}}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="Translate This Entry" Style="{DynamicResource PrimaryButton}"
                            Command="{Binding TranslateSelectedCommand}" Margin="0,0,8,0" />
                    <Button Content="Reset To Source" Style="{DynamicResource SecondaryButton}"
                            Command="{Binding ResetSelectedCommand}" />
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ProgressLabel}"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="12"
                               Margin="0,4,0,0" />
                </StackPanel>

                <ProgressBar Grid.Column="1"
                             Width="260"
                             Height="8"
                             Style="{DynamicResource AccentProgressBar}"
                             IsIndeterminate="{Binding IsBusy}"
                             VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>

